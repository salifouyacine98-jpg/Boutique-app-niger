@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color: transparent; }
html, body { font-family:'Inter',sans-serif; background:#F5F6FA; overflow-x:hidden; height:100%; }
body { display:flex; flex-direction:column; min-height:100vh; }

:root {
  --vert:#1B7A4E; --vert2:#23A066; --orange:#E8650A; --orange2:#FF7A1A;
  --bg:#F5F6FA; --blanc:#FFFFFF; --gris1:#F0F1F5; --gris2:#C8CBDA;
  --txt:#1A1D2E; --txt2:#6B7080; --rouge:#E03E3E; --bleu:#2E6BE6;
}

button { font-family:inherit; border:none; background:none; cursor:pointer; }
input, select, textarea { font-family:inherit; }

#root { flex:1; display:flex; flex-direction:column; }
.app-shell { flex:1; display:flex; flex-direction:column; max-width:480px; margin:0 auto; width:100%; background:var(--bg); min-height:100vh; position:relative; }

.screen { display:flex; flex-direction:column; flex:1; padding-bottom:90px; }

.auth-wrap { flex:1; display:flex; flex-direction:column; justify-content:center; padding:30px 24px; max-width:480px; margin:0 auto; width:100%; min-height:100vh; }
.auth-logo { font-size:46px; text-align:center; margin-bottom:6px; }
.auth-title { font-size:22px; font-weight:800; color:var(--txt); text-align:center; }
.auth-sub { font-size:13px; color:var(--txt2); text-align:center; margin-top:4px; margin-bottom:28px; }
.auth-field { margin-bottom:14px; }
.auth-label { font-size:12px; font-weight:600; color:var(--txt); margin-bottom:6px; display:block; }
.auth-input { width:100%; background:var(--blanc); border:1.5px solid var(--gris1); border-radius:12px; padding:13px 14px; font-size:14px; color:var(--txt); outline:none; }
.auth-input:focus { border-color:var(--vert2); }
.auth-btn { width:100%; background:var(--vert); color:#fff; font-weight:700; font-size:14px; border-radius:12px; padding:14px; margin-top:8px; }
.auth-btn:disabled { background:var(--gris2); }
.auth-switch { text-align:center; font-size:13px; color:var(--txt2); margin-top:18px; }
.auth-switch span { color:var(--bleu); font-weight:700; }
.auth-error { background:#FEECEC; color:var(--rouge); font-size:12px; font-weight:600; padding:10px 14px; border-radius:10px; margin-bottom:14px; }
.auth-success { background:#E6F5ED; color:var(--vert); font-size:12px; font-weight:600; padding:10px 14px; border-radius:10px; margin-bottom:14px; }

.header { padding:18px 16px 22px; color:#fff; position:relative; overflow:hidden; }
.header.vert { background:linear-gradient(135deg,var(--vert),#14603C); }
.header.orange { background:linear-gradient(135deg,var(--orange),#B04C06); }
.header.bleu { background:linear-gradient(135deg,var(--bleu),#1A4BA8); }
.header.violet { background:linear-gradient(135deg,#6B3FA0,#432566); }
.header-row { display:flex; align-items:center; gap:12px; margin-bottom:4px; }
.header-title { font-size:17px; font-weight:700; flex:1; }
.back-btn, .header-icon-btn { width:34px; height:34px; border-radius:10px; background:rgba(255,255,255,.2); color:#fff; font-size:16px; display:flex; align-items:center; justify-content:center; }

.nav-bar { background:var(--blanc); display:flex; padding:8px 8px 14px; border-top:1px solid var(--gris1); position:fixed; bottom:0; left:0; right:0; max-width:480px; margin:0 auto; z-index:50; }
.nav-item { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; padding:4px; }
.nav-icon { font-size:21px; opacity:.55; }
.nav-lbl { font-size:10px; font-weight:600; color:var(--txt2); }
.nav-item.active .nav-icon { opacity:1; }
.nav-item.active .nav-lbl { color:var(--vert); }
.nav-center { flex:1; display:flex; justify-content:center; align-items:center; margin-top:-22px; }
.nav-fab { width:52px; height:52px; border-radius:50%; background:var(--orange2); color:#fff; font-size:24px; display:flex; align-items:center; justify-content:center; box-shadow:0 4px 14px rgba(232,101,10,.4); border:3px solid var(--blanc); }

.section-title { font-size:13px; font-weight:700; color:var(--txt); padding:18px 16px 10px; display:flex; justify-content:space-between; align-items:center; }
.section-title .link { font-size:11px; color:var(--bleu); font-weight:600; }
.card { background:var(--blanc); border-radius:14px; padding:14px; box-shadow:0 2px 8px rgba(0,0,0,.05); }
.card-list { padding:0 16px; display:flex; flex-direction:column; gap:8px; }
.empty-state { text-align:center; padding:50px 30px; color:var(--txt2); }
.empty-state .ico { font-size:38px; margin-bottom:10px; }
.empty-state .txt { font-size:13px; line-height:1.5; }
.loading-state { text-align:center; padding:60px 30px; color:var(--txt2); font-size:13px; }

.input-group { padding:0 16px; margin-top:12px; }
.input-label { font-size:12px; font-weight:600; color:var(--txt); margin-bottom:6px; display:block; }
.input-field { width:100%; background:var(--blanc); border:1.5px solid var(--gris1); border-radius:12px; padding:12px 14px; font-size:14px; color:var(--txt); outline:none; }
.input-field:focus { border-color:var(--vert2); }

.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.5); display:flex; align-items:flex-end; justify-content:center; z-index:200; max-width:480px; margin:0 auto; }
.modal-sheet { background:var(--bg); width:100%; border-radius:22px 22px 0 0; max-height:88vh; overflow-y:auto; padding-bottom:24px; animation:slideUp .25s ease; }
@keyframes slideUp { from{transform:translateY(40px);opacity:0} to{transform:translateY(0);opacity:1} }
.modal-handle { width:40px; height:4px; background:var(--gris2); border-radius:4px; margin:10px auto 4px; }
.modal-header { padding:8px 16px 4px; display:flex; align-items:center; justify-content:space-between; }
.modal-title { font-size:16px; font-weight:700; color:var(--txt); }
.modal-close { font-size:20px; color:var(--txt2); padding:4px 8px; }

.btn-row { display:flex; gap:10px; padding:18px 16px 6px; }
.btn { flex:1; border-radius:12px; padding:13px; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; gap:6px; }
.btn-primary { background:var(--vert); color:#fff; }
.btn-primary:disabled { background:var(--gris2); }
.btn-secondary { background:var(--gris1); color:var(--txt); }
.btn-danger { background:#FEECEC; color:var(--rouge); }

.toast { position:fixed; bottom:100px; left:50%; transform:translateX(-50%); background:var(--txt); color:#fff; padding:10px 20px; border-radius:30px; font-size:13px; font-weight:600; z-index:300; opacity:0; transition:opacity .25s, bottom .25s; pointer-events:none; white-space:nowrap; max-width:90%; text-align:center; }
.toast.show { opacity:1; bottom:120px; }

.home-ca-label { font-size:11px; opacity:.7; margin-bottom:4px; }
.home-ca { font-size:28px; font-weight:800; letter-spacing:-1px; }
.home-ca span { font-size:13px; font-weight:500; opacity:.8; }
.home-ca-date { font-size:11px; opacity:.6; margin-top:3px; }
.pills-row { display:flex; gap:8px; margin-top:12px; flex-wrap:wrap; }
.pill { background:rgba(255,255,255,.15); border-radius:20px; padding:5px 12px; font-size:11px; font-weight:600; }
.quick-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; padding:18px 16px 0; }
.quick-card { background:var(--blanc); border-radius:16px; padding:14px; box-shadow:0 2px 10px rgba(0,0,0,.06); }
.qc-icon { width:38px; height:38px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:9px; }
.qc-icon.green{background:#E6F5ED;} .qc-icon.orange{background:#FEF0E6;}
.qc-icon.blue{background:#E8EFFE;} .qc-icon.red{background:#FEECEC;}
.qc-label { font-size:12px; font-weight:700; color:var(--txt); }
.qc-val { font-size:11px; color:var(--txt2); margin-top:2px; }
.alert-item { background:var(--blanc); border-radius:12px; padding:12px 14px; display:flex; align-items:center; gap:12px; box-shadow:0 1px 6px rgba(0,0,0,.05); }
.alert-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.alert-dot.rouge{background:var(--rouge);} .alert-dot.orange{background:var(--orange2);}
.alert-txt { font-size:12px; color:var(--txt); font-weight:500; flex:1; }
.alert-badge { font-size:11px; font-weight:700; padding:3px 8px; border-radius:10px; }
.alert-badge.rouge{background:#FEECEC;color:var(--rouge);}
.alert-badge.orange{background:#FEF0E6;color:var(--orange);}

.search-box { margin:14px 16px 0; background:var(--blanc); border-radius:12px; padding:11px 14px; display:flex; align-items:center; gap:8px; box-shadow:0 1px 6px rgba(0,0,0,.06); }
.search-box input { border:none; outline:none; font-size:13px; flex:1; background:transparent; color:var(--txt); }
.stock-item { background:var(--blanc); border-radius:12px; padding:12px 14px; display:flex; align-items:center; gap:12px; box-shadow:0 1px 6px rgba(0,0,0,.05); }
.stock-emoji { font-size:24px; width:40px; text-align:center; }
.stock-info { flex:1; }
.stock-name { font-size:13px; font-weight:700; color:var(--txt); }
.stock-meta { font-size:11px; color:var(--txt2); margin-top:1px; }
.stock-qty { font-size:14px; font-weight:800; text-align:right; }
.stock-qty.ok{color:var(--vert);} .stock-qty.bas{color:var(--orange);} .stock-qty.vide{color:var(--rouge);}
.stock-qty-lbl { font-size:9px; color:var(--txt2); font-weight:500; text-align:right; }

.prod-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; padding:14px 16px 0; }
.prod-card { background:var(--blanc); border-radius:12px; padding:10px 8px; text-align:center; box-shadow:0 1px 6px rgba(0,0,0,.05); position:relative; border:2px solid transparent; }
.prod-card.selected { border-color:var(--vert2); }
.prod-emoji { font-size:24px; margin-bottom:4px; }
.prod-name { font-size:10px; font-weight:600; color:var(--txt); line-height:1.2; }
.prod-price { font-size:10px; color:var(--vert); font-weight:700; margin-top:2px; }
.prod-stock { font-size:9px; color:var(--txt2); }
.prod-stock.vide { color:var(--rouge); font-weight:700; }
.prod-badge { position:absolute; top:6px; right:6px; background:var(--vert2); color:#fff; font-size:9px; font-weight:700; width:16px; height:16px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.cart-bar { margin:14px 16px 0; background:var(--txt); border-radius:16px; padding:14px 16px; color:#fff; display:flex; align-items:center; justify-content:space-between; position:sticky; bottom:100px; }
.cart-info .cart-n { font-size:11px; opacity:.7; }
.cart-info .cart-tot { font-size:17px; font-weight:800; }
.cart-info .cart-tot span { font-size:11px; font-weight:500; }
.pay-btn { background:var(--orange2); border-radius:12px; color:#fff; font-weight:700; font-size:13px; padding:10px 16px; }
.pay-btn:disabled { background:var(--gris2); }

.cart-line { display:flex; align-items:center; gap:10px; padding:10px 16px; border-bottom:1px solid var(--gris1); }
.cart-line-emoji { font-size:20px; width:32px; }
.cart-line-info { flex:1; }
.cart-line-name { font-size:13px; font-weight:600; color:var(--txt); }
.cart-line-price { font-size:11px; color:var(--txt2); }
.qty-ctrl { display:flex; align-items:center; gap:8px; }
.qty-btn { width:26px; height:26px; border-radius:8px; background:var(--gris1); display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; color:var(--txt); }
.qty-val { font-size:13px; font-weight:700; min-width:18px; text-align:center; }
.cart-line-total { font-size:13px; font-weight:700; color:var(--txt); min-width:60px; text-align:right; }

.recu-paper { background:#fff; margin:16px; border-radius:12px; padding:20px; box-shadow:0 4px 20px rgba(0,0,0,.08); }
.recu-shop { text-align:center; font-size:15px; font-weight:800; color:var(--txt); }
.recu-tagline { text-align:center; font-size:10px; color:var(--txt2); margin-top:2px; }
.recu-divider { border:none; border-top:1px dashed var(--gris2); margin:12px 0; }
.recu-meta { font-size:10px; color:var(--txt2); display:flex; justify-content:space-between; flex-wrap:wrap; gap:4px; }
.recu-table { width:100%; margin-top:10px; border-collapse:collapse; }
.recu-table th { font-size:10px; font-weight:600; color:var(--txt2); text-align:left; padding-bottom:6px; }
.recu-table th:last-child { text-align:right; }
.recu-table td { font-size:11px; color:var(--txt); padding:4px 0; }
.recu-table td:last-child { text-align:right; font-weight:600; }
.recu-total-row { display:flex; justify-content:space-between; font-size:15px; font-weight:800; color:var(--txt); margin-top:6px; }
.recu-monnaie { font-size:11px; color:var(--txt2); display:flex; justify-content:space-between; margin-top:4px; }
.recu-merci { text-align:center; margin-top:12px; font-size:11px; color:var(--txt2); }
.recu-merci strong { color:var(--vert); }
.recu-actions { display:flex; gap:10px; margin:6px 16px 10px; }
.recu-btn { flex:1; border-radius:14px; padding:13px; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; gap:6px; }
.recu-btn.print{background:var(--vert);color:#fff;}
.recu-btn.whats{background:#25D366;color:#fff;}
.recu-btn.new{background:var(--gris1);color:var(--txt);margin:0 16px 8px;}

.stats-period { display:flex; gap:8px; padding:14px 16px 0; }
.period-btn { flex:1; border-radius:10px; padding:8px; font-size:12px; font-weight:600; background:var(--gris1); color:var(--txt2); }
.period-btn.active { background:var(--bleu); color:#fff; }
.stats-kpi { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:14px 16px 0; }
.kpi-card { background:var(--blanc); border-radius:14px; padding:14px; box-shadow:0 2px 8px rgba(0,0,0,.06); }
.kpi-label { font-size:11px; color:var(--txt2); font-weight:500; }
.kpi-val { font-size:19px; font-weight:800; color:var(--txt); margin:4px 0; }
.kpi-val span { font-size:11px; font-weight:500; }
.chart-card { background:var(--blanc); border-radius:14px; padding:16px; margin:12px 16px 0; box-shadow:0 2px 8px rgba(0,0,0,.06); }
.chart-label { font-size:12px; font-weight:700; color:var(--txt); margin-bottom:14px; }
.bars { display:flex; gap:8px; align-items:flex-end; height:80px; }
.bar-wrap { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; }
.bar { width:100%; border-radius:6px 6px 0 0; background:var(--vert); min-height:3px; }
.bar.today { background:var(--orange2); }
.bar-day { font-size:9px; color:var(--txt2); font-weight:600; }
.top-prod-item { background:var(--blanc); border-radius:12px; padding:12px 14px; display:flex; align-items:center; gap:12px; box-shadow:0 1px 6px rgba(0,0,0,.05); }
.tp-rank { font-size:13px; font-weight:800; color:var(--txt2); width:18px; }
.tp-emoji { font-size:20px; }
.tp-name { flex:1; font-size:12px; font-weight:600; color:var(--txt); }
.tp-sales { font-size:11px; color:var(--txt2); }
.tp-val { font-size:13px; font-weight:700; color:var(--vert); }

.menu-item { background:var(--blanc); border-radius:12px; padding:14px; display:flex; align-items:center; gap:14px; box-shadow:0 1px 6px rgba(0,0,0,.05); }
.menu-icon { font-size:22px; width:30px; text-align:center; }
.menu-label { flex:1; font-size:13px; font-weight:600; color:var(--txt); }
.menu-arrow { color:var(--txt2); font-size:14px; }
.person-item { background:var(--blanc); border-radius:12px; padding:13px 14px; display:flex; align-items:center; gap:12px; box-shadow:0 1px 6px rgba(0,0,0,.05); }
.person-avatar { width:38px; height:38px; border-radius:50%; background:var(--gris1); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px; color:var(--txt2); flex-shrink:0; }
.person-info { flex:1; }
.person-name { font-size:13px; font-weight:700; color:var(--txt); }
.person-meta { font-size:11px; color:var(--txt2); }
.person-debt { font-size:13px; font-weight:800; }
.person-debt.has { color:var(--rouge); }
.person-debt.none { color:var(--vert2); }
